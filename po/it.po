#: ../apps/ll-cli/src/main.cpp:367
msgid ""
"Usage: ll-cli search [OPTIONS] KEYWORDS\n"
"\n"
"Example:\n"
"# find remotely application(s), base(s) or runtime(s) by keywords\n"
"ll-cli search org.deepin.demo\n"
"# find all of app of remote\n"
"ll-cli search .\n"
"# find all of base(s) of remote\n"
"ll-cli search . --type=base\n"
"# find all of runtime(s) of remote\n"
"ll-cli search . --type=runtime"
msgstr ""
"Uso: ll-cli search [OPZIONI] PAROLE_CHIAVE\n"
"\n"
"Esempio:\n"
"# trova applicazioni, basi o runtime in remoto per parole chiave\n"
"ll-cli search org.deepin.demo\n"
"# trova tutte le app nel repository remoto\n"
"ll-cli search .\n"
"# trova tutte le basi nel repository remoto\n"
"ll-cli search . --type=base\n"
"# trova tutti i runtime nel repository remoto\n"
"ll-cli search . --type=runtime"

