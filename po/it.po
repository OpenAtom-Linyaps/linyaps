#: ../apps/ll-cli/src/main.cpp:122
msgid ""
"Usage: ll-cli run [OPTIONS] APP [COMMAND...]\n"
"\n"
"Example:\n"
"# run application by appid\n"
"ll-cli run org.deepin.demo\n"
"# execute commands in the container rather than running the application\n"
"ll-cli run org.deepin.demo bash\n"
"ll-cli run org.deepin.demo -- bash\n"
"ll-cli run org.deepin.demo -- bash -x /path/to/bash/script"
msgstr ""
"Uso: ll-cli run [OPZIONI] APP [COMANDO...]\n"
"\n"
"Esempio:\n"
"# esegue l'applicazione tramite appid\n"
"ll-cli run org.deepin.demo\n"
"# esegue comandi nel container invece dell'applicazione\n"
"ll-cli run org.deepin.demo bash\n"
"ll-cli run org.deepin.demo -- bash\n"
"ll-cli run org.deepin.demo -- bash -x /percorso/dello/script/bash"

