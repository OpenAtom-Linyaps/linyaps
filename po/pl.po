#: ../apps/ll-cli/src/main.cpp:400
msgid ""
"Usage: ll-cli list [OPTIONS]\n"
"\n"
"Example:\n"
"# show installed application(s), base(s) or runtime(s)\n"
"ll-cli list\n"
