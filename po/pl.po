"# pokaż zainstalowane bazy\n"
"ll-cli list --type=base\n"
"# pokaż zainstalowane środowiska wykonawcze\n"
"ll-cli list --type=runtime\n"
"# pokaż najnowsze wersje zainstalowanych aplikacji\n"
"ll-cli list --upgradable\n"

