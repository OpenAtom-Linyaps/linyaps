#: ../apps/ll-cli/src/main.cpp:367
msgid ""
"Usage: ll-cli search [OPTIONS] KEYWORDS\n"
"\n"
"Example:\n"
"# find remotely application(s), base(s) or runtime(s) by keywords\n"
"ll-cli search org.deepin.demo\n"
"# find all of app of remote\n"
"ll-cli search .\n"
"# find all of base(s) of remote\n"
"ll-cli search . --type=base\n"
"# find all of runtime(s) of remote\n"
"ll-cli search . --type=runtime"
msgstr ""
"Use: ll-cli search [OPÇÕES] PALAVRAS-CHAVE\n"
"\n"
"Exemplos:\n"
"# buscar aplicativos, bases ou runtimes no repositório remoto por palavras-chave\n"
"ll-cli search org.deepin.demo\n"
"# listar todos os aplicativos do repositório remoto\n"
"ll-cli search .\n"
"# listar todas as bases do repositório remoto\n"
"ll-cli search . --type=base\n"
"# listar todos os runtimes do repositório remoto\n"
"ll-cli search . --type=runtime"

