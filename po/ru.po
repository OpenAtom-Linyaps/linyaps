#: ../apps/ll-cli/src/main.cpp:359
msgid ""
"Usage: ll-cli search [OPTIONS] KEYWORDS\n"
"\n"
"Example:\n"
"# find remotely application(s), base(s) or runtime(s) by keywords\n"
"ll-cli search org.deepin.demo\n"
"# find all of app of remote\n"
"ll-cli search .\n"
"# find all of base(s) of remote\n"
"ll-cli search . --type=base\n"
"# find all of runtime(s) of remote\n"
"ll-cli search . --type=runtime"
msgstr ""
"Использование: ll-cli search [ПАРАМЕТРЫ] КЛЮЧЕВЫЕ_СЛОВА\n"
"\n"
"Пример:\n"
"# найти удаленное(ые) приложение(я), базу(ы) или среду(ы) выполнения по ключевым словам\n"
"ll-cli search org.deepin.demo\n"
"# найти все приложения в удаленном репозитории\n"
"ll-cli search .\n"
"# найти все базы в удаленном репозитории\n"
"ll-cli search . --type=base\n"
"# найти все среды выполнения в удаленном репозитории\n"
"ll-cli search . --type=runtime"

